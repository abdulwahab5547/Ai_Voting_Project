# Copy this file to ".env" and fill in real values.
# The .env file is git-ignored.

# Flask session secret (any long random string)
SECRET_KEY=change-me-to-a-long-random-string

# Admin Panel password (used on /admin/login)
ADMIN_PASSWORD=admin123

# Face match threshold. Lower = stricter. 0.5 is a good default.
FACE_TOLERANCE=0.5

# ESP32 serial port.
#   Windows: COM3, COM4, COM5 ...   (check Device Manager)
#   Linux  : /dev/ttyUSB0 or /dev/ttyACM0
#   macOS  : /dev/cu.SLAB_USBtoUART or /dev/cu.usbserial-XXXX
# Leave blank to run the app without ESP32 (events are logged only).
SERIAL_PORT=
SERIAL_BAUD=115200

# Election display title (shown in the navbar)
ELECTION_TITLE=Smart Digital Voting Machine
